{
  "name": "@interop/edv-server",
  "description": "Encrypted Data Vault (EDV) server: a fastify plugin and standalone server with filesystem storage.",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "pnpm run clear && tsc",
    "clear": "rimraf dist/*",
    "dev": "tsx watch src/start.ts",
    "start": "node dist/start.js",
    "fix": "eslint --fix src test && pnpm run format",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.md\"",
    "lint": "eslint src test",
    "prepare": "pnpm run build",
    "rebuild": "pnpm run clear && pnpm run build",
    "test": "pnpm run fix && pnpm run lint && pnpm run test:node",
    "test:node": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@interop/data-integrity-core": "^7.0.0",
    "@interop/did-method-key": "^7.3.1",
    "@interop/ed25519-signature": "^7.1.1",
    "@interop/ed25519-verification-key": "^8.0.0",
    "@interop/http-digest-header": "^2.3.2",
    "@interop/http-signature-zcap-verify": "^12.0.3",
    "@interop/jsonld-signatures": "^11.7.1",
    "@interop/security-document-loader": "^9.3.0",
    "@interop/zcap": "^11.0.2",
    "base58-universal": "^2.0.0",
    "etag": "^1.8.1",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@interop/edv-client": "^17.0.1",
    "@interop/ezcap": "^7.2.0",
    "@interop/http-client": "^1.0.3",
    "@interop/http-signature-zcap-invoke": "^6.2.2",
    "@interop/x25519-key-agreement-key": "^4.0.2",
    "@types/etag": "^1.8.4",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "edv",
    "encrypted-data-vault",
    "zcap",
    "fastify"
  ],
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24.0"
  },
  "author": {
    "name": "Interop Alliance",
    "url": "https://github.com/interop-alliance/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/interop-alliance/edv-server.git"
  },
  "homepage": "https://github.com/interop-alliance/edv-server",
  "bugs": "https://github.com/interop-alliance/edv-server/issues"
}
